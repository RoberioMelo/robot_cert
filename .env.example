# --- Pastas padrão (se o painel e o API rodarem no mesmo PC sem agente) ---
CERT_SOURCE_DIR=./certificados
CERT_EXPIRED_DIR=./certificados_vencidos

# --- Supabase (servidor: guarda config e snapshots) ---
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..._service_role_...

# --- Segurança: mesma chave no servidor e no agente Windows (obrigatório se definida) ---
# API_KEY=uma_senha_longa_aleatória

# --- Agente (mesmo ficheiro .env na raiz; ou use agent/.env) ---
# CERT_ROBOT_BASE_URL=http://127.0.0.1:8020
# CERT_ROBOT_API_KEY=  (só com API_KEY no servidor; senão omita)
# AGENT_SOURCE=D:\caminho\absoluto\certificados
# AGENT_EXPIRED=D:\caminho\absoluto\certificados_vencidos
