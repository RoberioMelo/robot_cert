# ==============================================================
# CONFIGURAÇÕES DO AGENTE - CERTGUARD
# ==============================================================

# URL base do portal web. Se usar o Render, será o link do Render.
# Exemplo local: http://127.0.0.1:8020
CERT_ROBOT_BASE_URL=http://127.0.0.1:8020

# Se o servidor exigir chave de acesso (API_KEY), cole a mesma aqui:
CERT_ROBOT_API_KEY=

# Nome opcional para identificar essa máquina no portal
MACHINE_ID=Meu_Servidor_Windows
